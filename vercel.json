{
  "buildCommand": "echo 'Static site - no build needed'",
  "outputDirectory": ".",
  "public": true,
  "functions": {
    "api/listings.js":    { "memory": 128, "maxDuration": 10 },
    "api/contact.js":     { "memory": 128, "maxDuration": 10 },
    "api/sync-zillow.js": { "memory": 256, "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/sync-zillow", "schedule": "0 13 * * *" }
  ],
  "rewrites": [
    { "source": "/robots.txt", "destination": "/public/robots.txt" },
    { "source": "/sitemap.xml", "destination": "/public/sitemap.xml" },
    { "source": "/llms.txt", "destination": "/public/llms.txt" },
    { "source": "/a1b2c3d4e5f6g7h8.txt", "destination": "/public/a1b2c3d4e5f6g7h8.txt" },
    { "source": "/favicon.ico", "destination": "/public/favicon.ico" },
    { "source": "/faq", "destination": "/faq.html" },
    { "source": "/allegheny-county", "destination": "/neighborhoods/allegheny-county.html" },
    { "source": "/washington-county", "destination": "/neighborhoods/washington-county.html" },
    { "source": "/westmoreland-county", "destination": "/neighborhoods/westmoreland-county.html" },
    { "source": "/butler-county", "destination": "/neighborhoods/butler-county.html" },
    { "source": "/pittsburgh-real-estate-faq", "destination": "/public/pittsburgh-real-estate-faq.html" },
    { "source": "/answers", "destination": "/answers.html" },
    {
      "source": "/((?!api/|local-intel/|neighborhoods/|public/|faq\\.html|answers\\.html).*)",
      "destination": "/index.html"
    }
  ]
}
